# Copy to .env for local overrides. All have sensible defaults — nothing here is
# required to run the app locally (`npm run seed && npm run dev`).

# --- server ---
# Port the API listens on.
PORT=4000
# Absolute path to the SQLite file (":memory:" is used by the test suite).
DATABASE_PATH=./server/data/salary.db
# pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
# In production, point this at the built SPA so the API also serves the UI.
# Leave unset in development (Vite serves the UI and proxies /api).
# WEB_DIST_PATH=./web/dist

# --- web (build-time) ---
# Base URL the SPA calls. Defaults to "/api" (same-origin). Only set this if the
# API is on a different origin than the web app.
# VITE_API_BASE=/api
